# Alpaca-bot environment template
# Copy to .env and fill in values.

# Paper trading base URL (recommended for swing)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Options bot API host (defaults to paper; independent of ALPACA_BASE_URL)
# OPTIONS_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Live swing bot
SWING_API_KEY=
SWING_API_SECRET=

# Options spread bot (paper; legacy DAY_API_* names still work)
OPTIONS_API_KEY=
OPTIONS_API_SECRET=

# Paper swing mirror (same bot as swing, paper keys/host)
PAPER_SWING_API_KEY=
PAPER_SWING_API_SECRET=
# PAPER_SWING_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Safety override (DO NOT set unless you intend live trading)
# ALLOW_LIVE_TRADING=0
# OPTIONS_ALLOW_LIVE=0
